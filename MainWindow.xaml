<Window x:Class="StdfAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:StdfAnalyzer.Converters"
        xmlns:controls="clr-namespace:StdfAnalyzer.Controls"
        Title="STDF Analyzer" Width="1400" Height="900"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        AllowDrop="True"
        Drop="Window_Drop" DragOver="Window_DragOver"
        Loaded="MainWindow_Loaded">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:PassFailToBrushConverter x:Key="PassFailBrush" />
        <converters:YieldToColorConverter x:Key="YieldColor" />

        <!-- Reorder ListBox item style -->
        <Style x:Key="QueueItemStyle" TargetType="ListBoxItem">
            <Setter Property="AllowDrop" Value="True" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" Background="{StaticResource BgCardBrush}"
                                CornerRadius="6" Padding="12,10" BorderThickness="1"
                                BorderBrush="Transparent">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FF2A3A4A" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource BgLightBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top toolbar -->
        <Border Grid.Row="0" Background="{StaticResource BgLightBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="STDF" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                    <TextBlock Text=" Analyzer" FontSize="20" FontWeight="Light"
                               Foreground="{StaticResource FgBrush}" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="添加文件" Style="{StaticResource ModernButton}"
                            Click="BtnAddFile_Click" Margin="0,0,8,0" />
                    <Button Content="导出CSV" Style="{StaticResource ModernButton}"
                            Command="{Binding ExportCsvCommand}"
                            IsEnabled="{Binding HasData}" Margin="0,0,8,0" />
                    <Button Content="转TXT文件" Style="{StaticResource ModernButton}"
                            Command="{Binding ExportTxtMapCommand}"
                            IsEnabled="{Binding HasData}" Margin="0,0,8,0" />
                    <Button Content="生成TMB文件" Style="{StaticResource ModernButton}"
                            Command="{Binding ExportTmbCommand}"
                            IsEnabled="{Binding HasData}" Margin="0,0,8,0" />
                    <Button Content="转标准文件" Style="{StaticResource ModernButton}"
                            Command="{Binding ExportStandardExcelCommand}"
                            IsEnabled="{Binding HasData}" Margin="0,0,8,0" />
                    <Button Content="返回队列" Style="{StaticResource ModernButton}"
                            Click="BtnBackToQueue_Click"
                            IsEnabled="{Binding HasData}" Margin="0,0,8,0" />
                    <Button Content="清除全部" Style="{StaticResource ModernButton}"
                            Click="BtnClearAll_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content area: 3 states -->
        <Grid Grid.Row="1">

            <!-- State 1: Empty drop zone (no queue, no data) -->
            <Border Visibility="{Binding HasFileQueue, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                    Background="Transparent" Margin="40">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasData}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border BorderBrush="{StaticResource FgDimBrush}" BorderThickness="2"
                        CornerRadius="16" Background="Transparent" Padding="40">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{StaticResource FgDimBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="64"
                                   Foreground="{StaticResource FgDimBrush}" HorizontalAlignment="Center" Margin="0,0,0,16" />
                        <TextBlock Text="拖拽 STDF 文件到此处" FontSize="24" FontWeight="Light"
                                   Foreground="{StaticResource FgDimBrush}" HorizontalAlignment="Center" Margin="0,0,0,8" />
                        <TextBlock Text="支持 .std / .stdf 格式，可一次拖入多个文件" FontSize="14"
                                   Foreground="{StaticResource FgDimBrush}" HorizontalAlignment="Center" Opacity="0.6" />
                        <TextBlock Text="多文件按顺序解析，相同坐标自动取最新值覆盖" FontSize="13"
                                   Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" Opacity="0.7" Margin="0,6,0,0" />
                        <TextBlock Text="或点击右上角「添加文件」按钮" FontSize="13"
                                   Foreground="{StaticResource FgDimBrush}" HorizontalAlignment="Center" Opacity="0.5" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Border>

            <!-- State 2: File queue (has queue, no data) -->
            <Grid Margin="20"
                  Visibility="{Binding HasFileQueue, Converter={StaticResource BoolToVis}}">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasData}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Queue header -->
                <Border Grid.Row="0" Background="{StaticResource BgCardBrush}" CornerRadius="8"
                        Padding="20,14" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock Text="解析队列" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource FgBrush}" VerticalAlignment="Center" />
                            <TextBlock Foreground="{StaticResource FgDimBrush}" FontSize="14"
                                       VerticalAlignment="Center" Margin="12,0,0,0">
                                <Run Text="{Binding FileQueue.Count, Mode=OneWay}" />
                                <Run Text=" 个文件" />
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="拖拽行可调整顺序，排在后面的文件覆盖前面的同坐标数据"
                                   Foreground="{StaticResource FgDimBrush}" FontSize="12"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- File list with drag-to-reorder -->
                <ListBox x:Name="FileQueueList" Grid.Row="1"
                         ItemsSource="{Binding FileQueue}"
                         ItemContainerStyle="{StaticResource QueueItemStyle}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         AllowDrop="True"
                         PreviewMouseLeftButtonDown="FileQueue_PreviewMouseDown"
                         PreviewMouseMove="FileQueue_PreviewMouseMove"
                         Drop="FileQueue_Drop"
                         DragOver="FileQueue_DragOver">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Order number -->
                                <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}"
                                        CornerRadius="4" Width="28" Height="28"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Order}" Foreground="White"
                                               FontWeight="Bold" FontSize="13"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <!-- Drag handle -->
                                <TextBlock Grid.Column="1" Text="&#xE700;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" Foreground="{StaticResource FgDimBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           ToolTip="拖拽调整顺序" Opacity="0.5" />

                                <!-- File name -->
                                <TextBlock Grid.Column="2" Text="{Binding FileName}"
                                           Foreground="{StaticResource FgBrush}" FontSize="14"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                           Margin="4,0,0,0" />

                                <!-- File size -->
                                <TextBlock Grid.Column="3" Text="{Binding FileSize}"
                                           Foreground="{StaticResource FgDimBrush}" FontSize="12"
                                           VerticalAlignment="Center" HorizontalAlignment="Right"
                                           Margin="0,0,8,0" />

                                <!-- Action buttons -->
                                <StackPanel Grid.Column="4" Orientation="Horizontal">
                                    <Button Content="&#xE70E;" FontFamily="Segoe MDL2 Assets"
                                            FontSize="12" ToolTip="上移"
                                            Command="{Binding DataContext.MoveFileUpCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" Foreground="{StaticResource FgDimBrush}"
                                            BorderThickness="0" Padding="6,4" Cursor="Hand" />
                                    <Button Content="&#xE70D;" FontFamily="Segoe MDL2 Assets"
                                            FontSize="12" ToolTip="下移"
                                            Command="{Binding DataContext.MoveFileDownCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" Foreground="{StaticResource FgDimBrush}"
                                            BorderThickness="0" Padding="6,4" Cursor="Hand" />
                                    <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                            FontSize="12" ToolTip="移除"
                                            Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" Foreground="{StaticResource ErrorBrush}"
                                            BorderThickness="0" Padding="6,4" Cursor="Hand" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Bottom action bar -->
                <Border Grid.Row="2" Background="{StaticResource BgCardBrush}" CornerRadius="8"
                        Padding="20,14" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Foreground="{StaticResource FgDimBrush}" FontSize="13"
                                   VerticalAlignment="Center">
                            <Run Text="可继续拖入文件添加到队列，或点击「添加文件」" />
                        </TextBlock>

                        <Button Grid.Column="1" Content="清空队列"
                                Style="{StaticResource ModernButton}"
                                Command="{Binding ClearQueueCommand}"
                                Background="{StaticResource BgLightBrush}"
                                Margin="0,0,8,0" />

                        <Button Grid.Column="2" Content="添加更多文件"
                                Style="{StaticResource ModernButton}"
                                Click="BtnAddFile_Click"
                                Background="{StaticResource BgLightBrush}"
                                Margin="0,0,8,0" />

                        <Button Grid.Column="3" Content="  开始解析  "
                                Style="{StaticResource ModernButton}"
                                Command="{Binding ParseAllCommand}"
                                FontSize="15" FontWeight="SemiBold"
                                Padding="24,10" />
                    </Grid>
                </Border>
            </Grid>

            <!-- State 3: Results tabs (has data) -->
            <TabControl x:Name="MainTabs"
                        Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}"
                        SelectedIndex="{Binding SelectedTabIndex}"
                        Background="Transparent" BorderThickness="0"
                        Padding="0">

                <!-- Summary tab -->
                <TabItem Header="概览">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                        <StackPanel Margin="20">
                            <!-- File info card -->
                            <Border Background="{StaticResource BgCardBrush}" CornerRadius="8"
                                    Padding="20" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="16" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.ColumnSpan="4" Text="文件信息"
                                               FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4" />

                                    <StackPanel Grid.Row="2" Grid.Column="0">
                                        <TextBlock Text="文件名" Foreground="{StaticResource FgDimBrush}" FontSize="12" />
                                        <TextBlock Text="{Binding CurrentResult.FileInfo.FileName}" FontSize="14"
                                                   Foreground="{StaticResource FgBrush}" FontWeight="Medium"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="1">
                                        <TextBlock Text="批次 (Lot)" Foreground="{StaticResource FgDimBrush}" FontSize="12" />
                                        <TextBlock Text="{Binding CurrentResult.FileInfo.LotId}" FontSize="14"
                                                   Foreground="{StaticResource FgBrush}" FontWeight="Medium" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="2">
                                        <TextBlock Text="晶圆 (Wafer)" Foreground="{StaticResource FgDimBrush}" FontSize="12" />
                                        <TextBlock Text="{Binding CurrentResult.FileInfo.WaferId}" FontSize="14"
                                                   Foreground="{StaticResource FgBrush}" FontWeight="Medium" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="3">
                                        <TextBlock Text="字节序" Foreground="{StaticResource FgDimBrush}" FontSize="12" />
                                        <TextBlock x:Name="EndianText" FontSize="14" Foreground="{StaticResource FgBrush}" FontWeight="Medium" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Merge info card -->
                            <Border Background="{StaticResource BgCardBrush}" CornerRadius="8"
                                    Padding="20" Margin="0,0,0,16"
                                    Visibility="{Binding CurrentResult.FileInfo.IsMerged, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="多文件合并" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource WarningBrush}" />
                                        <TextBlock FontSize="14" Foreground="{StaticResource FgDimBrush}"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                                   Text="{Binding CurrentResult.FileInfo.MergedFileCount, StringFormat='共 {0} 个文件，相同坐标取最新值'}" />
                                    </StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="合并前芯片数" Foreground="{StaticResource FgDimBrush}" FontSize="12" />
                                            <TextBlock Text="{Binding CurrentResult.FileInfo.PreMergeParts}" FontSize="20"
                                                       FontWeight="Bold" Foreground="{StaticResource FgBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="覆盖(同坐标)" Foreground="{StaticResource FgDimBrush}" FontSize="12" />
                                            <TextBlock Text="{Binding CurrentResult.FileInfo.OverwrittenParts}" FontSize="20"
                                                       FontWeight="Bold" Foreground="{StaticResource WarningBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="合并后芯片数" Foreground="{StaticResource FgDimBrush}" FontSize="12" />
                                            <TextBlock Text="{Binding CurrentResult.FileInfo.TotalParts}" FontSize="20"
                                                       FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                        </StackPanel>
                                    </Grid>
                                    <ItemsControl Margin="0,12,0,0"
                                                  ItemsSource="{Binding CurrentResult.FileInfo.MergedFileNames}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource BgLightBrush}" CornerRadius="4"
                                                        Padding="8,4" Margin="0,0,6,4">
                                                    <TextBlock Text="{Binding}" Foreground="{StaticResource FgBrush}" FontSize="12" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Statistics cards -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="总芯片数" Foreground="{StaticResource FgDimBrush}" FontSize="13" />
                                        <TextBlock Text="{Binding CurrentResult.FileInfo.TotalParts}" FontSize="32"
                                                   FontWeight="Bold" Foreground="{StaticResource FgBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="通过" Foreground="{StaticResource FgDimBrush}" FontSize="13" />
                                        <TextBlock Text="{Binding CurrentResult.FileInfo.PassCount}" FontSize="32"
                                                   FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="4" Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="失败" Foreground="{StaticResource FgDimBrush}" FontSize="13" />
                                        <TextBlock Text="{Binding CurrentResult.FileInfo.FailCount}" FontSize="32"
                                                   FontWeight="Bold" Foreground="{StaticResource ErrorBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="6" Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="良率" Foreground="{StaticResource FgDimBrush}" FontSize="13" />
                                        <TextBlock FontSize="32" FontWeight="Bold"
                                                   Foreground="{Binding CurrentResult.FileInfo.Yield, Converter={StaticResource YieldColor}}"
                                                   Text="{Binding CurrentResult.FileInfo.Yield, StringFormat={}{0:F2}%}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Bin statistics -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- HBin -->
                                <Border Grid.Column="0" Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="Hard Bin 分布" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12" />
                                        <DataGrid ItemsSource="{Binding HbinTable}" MaxHeight="260"
                                                  AutoGenerateColumns="False"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  HeadersVisibility="Column"
                                                  CanUserSortColumns="True">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="HBin" Binding="{Binding Bin}" Width="70" />
                                                <DataGridTextColumn Header="数量" Binding="{Binding 数量}" Width="80" />
                                                <DataGridTextColumn Header="占比" Binding="{Binding 占比}" Width="*" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>

                                <!-- SBin -->
                                <Border Grid.Column="2" Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="Soft Bin 分布" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12" />
                                        <DataGrid ItemsSource="{Binding SbinTable}" MaxHeight="260"
                                                  AutoGenerateColumns="False"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  HeadersVisibility="Column"
                                                  CanUserSortColumns="True">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="SBin" Binding="{Binding Bin}" Width="70" />
                                                <DataGridTextColumn Header="数量" Binding="{Binding 数量}" Width="80" />
                                                <DataGridTextColumn Header="占比" Binding="{Binding 占比}" Width="*" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Record counts diagnostic -->
                            <Border Background="{StaticResource BgCardBrush}" CornerRadius="8"
                                    Padding="20" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="解析诊断" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource FgDimBrush}" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding CurrentResult.FileInfo.RecordCounts}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource BgLightBrush}" CornerRadius="4"
                                                        Padding="10,4" Margin="0,0,8,4">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Key}" Foreground="{StaticResource AccentBrush}"
                                                                   FontWeight="SemiBold" FontSize="13" />
                                                        <TextBlock Text=": " Foreground="{StaticResource FgDimBrush}" FontSize="13" />
                                                        <TextBlock Text="{Binding Value}" Foreground="{StaticResource FgBrush}" FontSize="13" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Test info card -->
                            <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="测试项汇总" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12" />
                                    <TextBlock Foreground="{StaticResource FgDimBrush}" FontSize="13"
                                               Text="{Binding CurrentResult.FileInfo.TestCount, StringFormat='共 {0} 个测试项'}"
                                               Margin="0,0,0,8" />
                                    <DataGrid x:Name="TestInfoGrid" MaxHeight="300"
                                              ItemsSource="{Binding TestInfoList}"
                                              AutoGenerateColumns="False"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              EnableRowVirtualization="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="编号" Binding="{Binding TestNum}" Width="80" />
                                            <DataGridTextColumn Header="名称" Binding="{Binding TestName}" Width="*" />
                                            <DataGridTextColumn Header="下限" Binding="{Binding LoLimit, StringFormat=G6}" Width="120" />
                                            <DataGridTextColumn Header="上限" Binding="{Binding HiLimit, StringFormat=G6}" Width="120" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Test data tab -->
                <TabItem Header="测试数据">
                    <DataGrid ItemsSource="{Binding TestDataTable}"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              Margin="4" />
                </TabItem>

                <!-- Wafer map tab -->
                <TabItem Header="晶圆图">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="当前显示: SBin" x:Name="TxtBinMode"
                                       Foreground="{StaticResource FgDimBrush}"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <Button x:Name="BtnToggleBin" Content="切换为 HBin"
                                    Style="{StaticResource ModernButton}"
                                    Click="BtnToggleBin_Click" Padding="12,5" FontSize="13" />
                        </StackPanel>
                        <controls:WaferMapControl x:Name="WaferMap" Grid.Row="1" />
                    </Grid>
                </TabItem>

                <!-- History tab -->
                <TabItem Header="历史">
                    <Grid Margin="16">
                        <DataGrid x:Name="HistoryGrid" AutoGenerateColumns="False"
                                  ItemsSource="{Binding ParseHistory}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="文件名" Binding="{Binding FileInfo.FileName}" Width="200" />
                                <DataGridTextColumn Header="批次" Binding="{Binding FileInfo.LotId}" Width="120" />
                                <DataGridTextColumn Header="晶圆" Binding="{Binding FileInfo.WaferId}" Width="100" />
                                <DataGridTextColumn Header="芯片数" Binding="{Binding FileInfo.TotalParts}" Width="80" />
                                <DataGridTextColumn Header="通过" Binding="{Binding FileInfo.PassCount}" Width="80" />
                                <DataGridTextColumn Header="失败" Binding="{Binding FileInfo.FailCount}" Width="80" />
                                <DataGridTextColumn Header="良率" Binding="{Binding FileInfo.Yield, StringFormat=F2}" Width="80" />
                                <DataGridTextColumn Header="测试项" Binding="{Binding FileInfo.TestCount}" Width="80" />
                                <DataGridTextColumn Header="耗时(ms)" Binding="{Binding ParseDuration.TotalMilliseconds, StringFormat=F0}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Loading overlay -->
        <Border Grid.Row="1"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                Background="#CC1E1E1E">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                             Foreground="{StaticResource AccentBrush}"
                             Background="{StaticResource BgCardBrush}" BorderThickness="0" />
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource FgDimBrush}"
                           FontSize="14" HorizontalAlignment="Center" Margin="0,12,0,0" />
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource BgLightBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="12,6">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource FgDimBrush}" FontSize="12" />
        </Border>
    </Grid>
</Window>
